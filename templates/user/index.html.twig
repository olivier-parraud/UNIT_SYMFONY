{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container" style="margin-top: 50px;">
    <h1>Mon Espace Utilisateur 👤</h1>
    
    {# La variable magique app.user permet d'afficher les infos de la personne connectée #}
    {% if app.user %}
        <p>Bienvenue sur ton profil !</p>
        <p>Ton identifiant de connexion est : <strong>{{ app.user.userIdentifier }}</strong></p>
    {% endif %}
</div>
{% endblock %}